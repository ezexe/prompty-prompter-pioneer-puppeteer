// Template — copy to `.mcp.json` at the plugin root (or merge into an existing one), then
// strip these comments (a live `.mcp.json` is plain JSON, not JSONC).
//
// A "connector" IS an MCP server. The old P4 `connector:` manifest maps onto this shape:
//   protocol: rest|graphql|websocket|mcp  ->  these are spoken BY the server; the Claude-side
//                                              transport is `type: stdio | http | sse`
//   endpoints / auth.env_var              ->  url / command+args / headers / env, with ${VAR} expansion
//   protocol: mcp                         ->  native (this file)
//
// "tools" are no longer a separate packaging unit: expose a capability either as an MCP tool
// here, or as a skill with bundled scripts/ (deterministic local helper).
//
// Plugin-bundled servers resolve paths with ${CLAUDE_PLUGIN_ROOT}. Do NOT ship a live entry that
// points at a server you haven't implemented — installing the plugin would try to spawn it.
{
  "mcpServers": {
    "example-stdio": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/servers/example/index.js"],
      "env": { "EXAMPLE_API_KEY": "${EXAMPLE_API_KEY}" }
    },
    "example-http": {
      "type": "http",
      "url": "https://api.example.com/mcp",
      "headers": { "Authorization": "Bearer ${EXAMPLE_TOKEN}" }
    },
    "example-sse": {
      "type": "sse",
      "url": "https://example.com/sse"
    }
  }
}
