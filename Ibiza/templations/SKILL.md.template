# allowed-tools: [Read, Grep]          # restrict this skill to a tool subset (omit to allow all)
# license: Apache-2.0
# --- P4 model, preserved as tolerated metadata (the skill loader ignores unknown metadata keys) ---
metadata:
  p4:
    type: skill                         # skill | tool | connector (informational; the standard infers type from location)
    phases: []                          # P4 gates this skill hooks, e.g. [pioneer, puppeteer]
    depends_on: []                      # skill names and/or P4 gate ids, e.g. [identity, vlds] — the closure must be satisfied
    optional_depends_on: []             # enhances the skill but is not required for closure
    interface:
      domains: []                       # knowledge domains this skill covers
      capabilities: []                  # named capabilities it adds (internal ids stay snake_case)
    hooks:
      on_prompty: []
      on_prompter: []
      on_pioneer: []
      on_puppeteer: []
    tiers: []                           # which closures include this skill — a closure = the skills whose tiers list it; resolved by skills/rubric (no docs/ file)
